{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with role management",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["customer", "admin"] },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["email", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "Store items (artisanal products, superfoods)",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "imageUrl": { "type": "string" },
        "stock": { "type": "number" },
        "createdAt": { "type": "timestamp" },
        "updatedAt": { "type": "timestamp" }
      },
      "required": ["name", "description", "price", "category", "stock", "createdAt", "updatedAt"]
    },
    "Order": {
      "title": "Order",
      "description": "Purchase records",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "customerEmail": { "type": "string" },
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "paymentVerified": { "type": "boolean" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "paid", "prepared", "shipped", "delivered"] },
        "paymentMethod": { "type": "string", "enum": ["yape", "card"] },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["userId", "items", "total", "status", "paymentMethod", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles and roles"
    },
    "products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Public catalog products"
    },
    "orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Customer orders"
    }
  }
}
