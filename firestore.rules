rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Core Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && 
        (
          request.auth.token.email.matches('(?i)^(jarp\\.199x|yahairapipiti4)@gmail\\.com$') || 
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
        ); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { 
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    // --- Entities Validation ---
    function isValidUser(data) {
      return data.keys().hasAll(['email', 'role']) &&
             data.email is string && data.email.size() <= 200 &&
             data.role in ['customer', 'admin'] &&
             (data.keys().hasAll(['name']) ? (data.name is string && data.name.size() <= 100) : true) &&
             (data.keys().hasAll(['createdAt']) ? data.createdAt is timestamp : true);
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'description', 'price', 'category', 'stock', 'createdAt', 'updatedAt']) &&
             data.name is string && data.name.size() <= 100 &&
             data.description is string && data.description.size() <= 2000 &&
             data.price is number && data.price >= 0 &&
             data.category is string && data.category.size() <= 50 &&
             data.stock is number && data.stock >= 0 &&
             (data.keys().hasAll(['status']) ? data.status in ['normal', 'in_production'] : true) &&
             (data.keys().hasAll(['imageUrl']) ? data.imageUrl is string && data.imageUrl.size() <= 1048576 : true) &&
             data.createdAt is timestamp && data.updatedAt is timestamp;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['userId', 'items', 'total', 'status', 'paymentMethod', 'createdAt']) &&
             data.userId is string && data.userId.size() <= 128 &&
             (data.keys().hasAll(['customerEmail']) ? data.customerEmail is string && data.customerEmail.size() <= 200 : true) &&
             (data.keys().hasAll(['customerName']) ? data.customerName is string && data.customerName.size() <= 200 : true) &&
             (data.keys().hasAll(['customerPhone']) ? data.customerPhone is string && data.customerPhone.size() <= 100 : true) &&
             (data.keys().hasAll(['paymentVerified']) ? data.paymentVerified is bool : true) &&
             data.items is list && data.items.size() > 0 && data.items.size() <= 100 &&
             data.total is number && data.total >= 0 &&
             data.status in ['pending', 'paid', 'prepared', 'shipped', 'delivered'] &&
             data.paymentMethod in ['yape', 'card'] &&
             data.createdAt is timestamp;
    }

    function isValidSettings(data) {
      return (data.keys().hasAll(['heroImageUrl']) ? data.heroImageUrl is string && data.heroImageUrl.size() <= 1048576 : true) &&
             (data.keys().hasAll(['aboutImageUrl']) ? data.aboutImageUrl is string && data.aboutImageUrl.size() <= 1048576 : true) &&
             (data.keys().hasAll(['innovateImageUrl']) ? data.innovateImageUrl is string && data.innovateImageUrl.size() <= 1048576 : true);
    }

    // --- Collections ---

    match /settings/{docId} {
      allow get: if docId == 'site';
      allow list: if false; // Only get by ID
      allow create: if isAdmin() && docId == 'site' && isValidSettings(incoming());
      allow update: if isAdmin() && docId == 'site' && isValidSettings(incoming());
    }

    match /users/{userId} {
      allow get: if isSignedIn() && isValidId(userId) && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      
      allow create: if isSignedIn() && isValidId(userId) && request.auth.uid == userId && 
                       isValidUser(incoming()) && 
                       // Ensure they don't self-assign admin unless they are the master admin
                       (incoming().role == 'customer' || request.auth.token.email == 'jarp.199x@gmail.com' || request.auth.token.email == 'yahairapipiti4@gmail.com');
      
      allow update: if isSignedIn() && isValidId(userId) && (request.auth.uid == userId || isAdmin()) &&
                       isValidUser(incoming()) &&
                       // Only admins can change roles
                       ((request.auth.uid == userId && incoming().role == existing().role) || isAdmin());
    }

    match /products/{productId} {
      allow get: if isValidId(productId);
      allow list: if true;
      allow create: if isAdmin() && isValidId(productId) && isValidProduct(incoming()) && incoming().createdAt == request.time;
      allow update: if isAdmin() && isValidId(productId) && isValidProduct(incoming()) && incoming().createdAt == existing().createdAt && incoming().updatedAt == request.time;
      allow delete: if isAdmin() && isValidId(productId);
    }

    match /orders/{orderId} {
      allow get: if isSignedIn() && isValidId(orderId) && (existing().userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      
      allow create: if isSignedIn() && isValidId(orderId) && isValidOrder(incoming()) && 
                       incoming().userId == request.auth.uid &&
                       incoming().createdAt == request.time;
      
      // Only admins can update status and verification. Use precise action-based affectedKeys constraints.
      allow update: if isAdmin() && isValidId(orderId) && 
                       incoming().userId == existing().userId &&
                       incoming().createdAt == existing().createdAt &&
                       (
                         (
                           incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']) && 
                           incoming().status in ['pending', 'paid', 'prepared', 'shipped', 'delivered']
                         ) || (
                           incoming().diff(existing()).affectedKeys().hasOnly(['paymentVerified', 'updatedAt']) && 
                           incoming().paymentVerified is bool
                         ) || (
                           incoming().diff(existing()).affectedKeys().hasOnly(['status', 'paymentVerified', 'updatedAt']) && 
                           incoming().status in ['pending', 'paid', 'prepared', 'shipped', 'delivered'] && 
                           incoming().paymentVerified is bool
                         )
                       );
    }
  }
}
